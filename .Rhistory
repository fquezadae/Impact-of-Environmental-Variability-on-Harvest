coord_sf(xlim = c(bb_exp["xmin"], bb_exp["xmax"]),
ylim = c(bb_exp["ymin"], bb_exp["ymax"])) +
theme_minimal(base_size = 12) +
labs(title = "Buffer radii around ports",
subtitle = "Cumulative: 0-30 / 0-60 / 0-90 / 0-120 km")
